{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "excludeFiles": [
        "node_modules/**/*",
        "public/img/**/*",
        "tests/**/*",
        ".git/**/*",
        ".github/**/*",
        ".history/**/*",
        "storage/logs/**/*",
        "storage/framework/cache/**/*",
        "storage/framework/sessions/**/*",
        "storage/framework/views/**/*"
      ]
    }
  },
  "routes": [
    {
      "src": "/(css|js|img|favicon.ico)(.*)",
      "dest": "/public/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
